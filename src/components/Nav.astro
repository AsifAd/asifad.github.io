---
import ThemeToggle from "./ThemeToggle.tsx";

const items = [
  { label: "About", href: "#about" },
  { label: "Skills", href: "#skills" },
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---

<nav class="fixed left-1/2 top-4 z-50 -translate-x-1/2 px-4">
  <div class="panel-strong flex items-center gap-1 rounded-full px-2 py-1.5 text-sm backdrop-blur-md">
    <a
      href="#top"
      class="flex items-center gap-2 rounded-full px-3 py-1.5 font-semibold tracking-tight text-[var(--color-fg)] hover:bg-[var(--color-accent-soft)]"
      style="font-family: var(--font-display); font-feature-settings: 'ss01';"
    >
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
      AD
    </a>
    <div class="hidden h-6 w-px ink-rule sm:block"></div>
    <div class="hidden items-center gap-0.5 sm:flex">
      {items.map((it) => (
        <a
          href={it.href}
          class="rounded-full px-3 py-1.5 text-[var(--color-fg-muted)] transition-colors hover:bg-[var(--color-accent-soft)] hover:text-[var(--color-fg)]"
        >
          {it.label}
        </a>
      ))}
    </div>
    <div class="ml-1 flex items-center gap-1">
      <ThemeToggle client:load />
      <a
        href="https://asifad.github.io/opensource-contributions/"
        target="_blank"
        rel="noopener"
        class="hidden rounded-full bg-[var(--color-panel)] px-3 py-1.5 font-mono text-xs text-[var(--color-fg)] hover:bg-[var(--color-accent-soft)] sm:block"
      >
        oss ↗
      </a>
      <a
        href="https://github.com/AsifAd"
        target="_blank"
        rel="noopener"
        class="hidden rounded-full bg-[var(--color-panel)] px-3 py-1.5 font-mono text-xs text-[var(--color-fg)] hover:bg-[var(--color-accent-soft)] sm:block"
      >
        github ↗
      </a>
    </div>
  </div>
</nav>
