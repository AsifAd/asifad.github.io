---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Background from "../components/Background.tsx";
import CommandPalette from "../components/ui/CommandPalette.tsx";
import { profile } from "../data/resume";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Asif Draxi — Site Reliability Engineer",
  description = "Asif Draxi — Site Reliability Engineer in Bengaluru. SRE, DevOps, and open source on GCP, AWS, and Azure. Portfolio, résumé, and upstream work on Ansible, Argo CD, and Jenkins.",
} = Astro.props;

const siteUrl = "https://asifad.github.io";
const personId = `${siteUrl}/#person`;
const websiteId = `${siteUrl}/#website`;
const webpageId = `${siteUrl}/#webpage`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: siteUrl,
      name: `${profile.name} — ${profile.title}`,
      description,
      inLanguage: "en",
      author: { "@id": personId },
    },
    {
      "@type": "ProfilePage",
      "@id": webpageId,
      url: siteUrl,
      name: title,
      description,
      isPartOf: { "@id": websiteId },
      about: { "@id": personId },
      inLanguage: "en",
    },
    {
      "@type": "Person",
      "@id": personId,
      name: profile.name,
      givenName: "Asif",
      familyName: "Draxi",
      jobTitle: profile.title,
      url: siteUrl,
      image: `${siteUrl}/og.png`,
      email: profile.email,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Bengaluru",
        addressCountry: "IN",
      },
      sameAs: [profile.links.github, profile.links.linkedin, profile.links.ossHub],
      mainEntityOfPage: { "@id": webpageId },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={siteUrl} />
    <link rel="me" href={profile.links.github} />
    <link rel="me" href={profile.links.linkedin} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var theme = stored === "light" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og.png`} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="relative min-h-screen">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-[var(--color-fg)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--color-bg)]"
    >
      Skip to content
    </a>
    <Background client:load />
    <CommandPalette client:load />
    <Nav />
    <main id="main-content" class="relative z-10">
      <slot />
    </main>
  </body>
</html>
